<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- parallel testing is used to test mutiple testing we can test methods, classes, tests togather-->
<!--mutil browser is doing parallel testing in different browser-->
<!-- Cross browsing parallel testing is not implementing-->

<suite name="parallel" parallel="classes" >
	
	<test thread-count="5" name="Test1">
		<parameter name="browsers" value="chrome"></parameter>
		<classes>
			<class name="testScript.LoginTest">
			<methods>
      <include name="verifyloginusingvalidcredentials"></include>
      
      </methods>
			</class>

		</classes>
	</test> <!--
	Test -->
	
	<test thread-count="5" name="Test2">
		<parameter name="browsers" value="firefox"></parameter>
		<classes>
			<class name="testScript.HomeTest">
			
			</class>

		</classes>
	</test>
</suite> <!--
Suite -->
